{
  "name": "trading-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:insecure-tls": "node scripts/next-dev-insecure.cjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "cap:sync": "npx cap sync android",
    "cap:open": "npx cap open android",
    "android:build:debug": "cd android && gradlew.bat assembleDebug",
    "android:build:release": "cd android && gradlew.bat bundleRelease",
    "android:publish-apk": "powershell -NoProfile -Command \"New-Item -ItemType Directory -Force public/downloads | Out-Null; Copy-Item android/app/build/outputs/apk/debug/app-debug.apk public/downloads/zuno-android.apk -Force\"",
    "test:notify-email": "node scripts/test-notify-email.mjs",
    "sync:webhook-triggers": "node scripts/sync-webhook-triggers-from-env.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/core": "^8.3.4",
