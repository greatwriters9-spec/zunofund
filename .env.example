# --- Public (may be bundled to the browser via NEXT_PUBLIC_*) ---
# Supabase project URL + anon key for client SDK
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: same project as NEXT_PUBLIC_SUPABASE_URL (subdomain before .supabase.co) — used for CLI/docs
SUPABASE_PROJECT_REF=
# Public: bundled — production builds should set this so auth redirect APIs pin to one canonical origin.
# Supabase Dashboard → Authentication → URL Configuration: Site URL + redirect wildcards, e.g.
#   https://your-domain.com/auth/callback**
NEXT_PUBLIC_SITE_URL=

# --- Server-only (never expose to client bundles) ---
# Server-only: Supabase project URL for cron/webhooks/service code (optional if same as NEXT_PUBLIC_SUPABASE_URL)
SUPABASE_URL=
# Server-only: service_role key — bypasses RLS; Vercel/server env only, never expose to client bundles
SUPABASE_SERVICE_ROLE_KEY=

# Server-only: deprecated — provisioning no longer creates Auth users; merchants must already be investors.
MERCHANT_DEFAULT_PASSWORD=

# Server-only: shared secret for Vercel Cron `Authorization: Bearer …` on /api/cron/run-daily-jobs
CRON_SECRET=

# Server-only: Supabase→App notify-email webhook (`x-webhook-secret`); rotate with DB trigger sync script if leaked
NOTIFICATION_WEBHOOK_SECRET=

# Optional deployment origin alias (scripts may fall back from WEBHOOK_NOTIFY_BASE_URL)
SITE_URL=

# Preferred explicit base for webhook-trigger sync SQL (origin only, no trailing slash)
WEBHOOK_NOTIFY_BASE_URL=

# Server-only: Resend API + verified sender for notify-email and transactional mail
RESEND_API_KEY=
# Prefer RESEND_FROM_EMAIL; NOTIFY_FROM_EMAIL is a backward-compatible alias used in code
RESEND_FROM_EMAIL=
NOTIFY_FROM_EMAIL=
#
# “Email rate limit exceeded”: Supabase’s built-in auth mail is heavily capped.
# Dashboard → Authentication → Emails → enable SMTP → use Resend:
#   Host smtp.resend.com | Port 587 | Username resend | Password = RESEND_API_KEY (same key as outbound mail).
#   “Sender email” must be allowed by Resend (verified domain; align with RESEND_FROM_EMAIL).

# Redirect URLs (wildcards): e.g. https://your-domain.com/reset-password** — match NEXT_PUBLIC_SITE_URL.
#
# Signup confirmation: only Supabase Auth should send the verify link (signed URL).
# Brand that email in Dashboard → Authentication → Email templates → Confirm signup (keep {{ .ConfirmationURL }}).
# Password reset: same place → “Reset password” template — paste HTML from `supabase/email-templates/reset-password-supabase.html`
# (keep {{ .ConfirmationURL }}; `redirectTo` is set by the browser via `resetPasswordForEmail` → `/reset-password`,
# using the same implicit email flow as signup — do not send resets from a server-only client or PKCE breaks in the mail app.)
# Webhook “welcome verify” mails are skipped in code — they linked to the dashboard before verify.
# Deliverability: SPF/DKIM on your Resend sending domain; align From with verified domain.
# Gmail may still flag password-reset links in-app; branded HTML + verified domain reduces spam; users can tap “Looks safe” if shown.

# Transactional email branding (Resend / notify-email webhook)
EMAIL_BRAND_NAME=Zuno
# Absolute URL to logo image for HTML emails (PNG/SVG served over HTTPS)
EMAIL_LOGO_URL=
# Optional: override site origin for transactional emails only (defaults NEXT_PUBLIC_SITE_URL)
EMAIL_WEBSITE_URL=
EMAIL_SUPPORT_EMAIL=
EMAIL_SUPPORT_PHONE=
# Separate lines with | e.g. Zuno Capital | 123 Main St | City, ST
EMAIL_COMPANY_ADDRESS=
EMAIL_FOOTER_TAGLINE=

# Optional absolute URLs (defaults: site + /dashboard, /admin, /forgot-password)
EMAIL_DASHBOARD_URL=
EMAIL_ADMIN_URL=
EMAIL_PASSWORD_RESET_URL=

# Stay connected row: pairs Label|URL|Label|URL — X|https://x.com/zuno|Telegram|https://t.me/…
# Omitting EMAIL_SOCIAL_LINKS uses the same placeholder X/Telegram/LinkedIn row as dev email-preview.
EMAIL_SOCIAL_LINKS=

# Optional: CDN/base for social SVGs (no trailing slash). Default: {EMAIL_WEBSITE_URL}/email/social
EMAIL_SOCIAL_ICON_BASE_URL=

# Social row: `icons` (default) uses /email/social/*.svg; `text` = gold text links only (no icons).
# EMAIL_SOCIAL_LINK_STYLE=text

# Production-only: allow /email-preview?secret=THIS_VALUE (≥8 chars). Omit locally.
EMAIL_PREVIEW_SECRET=

# --------------------------------------------------------------------
# Local dev only — antivirus/VPN HTTPS inspection can break Node TLS
# (same error for npm and for /dashboard via the Next proxy):
# • Run app (no extra install): npm run dev:insecure-tls
# • Before npm install works, in PowerShell:
#   $env:NODE_TLS_REJECT_UNAUTHORIZED="0"; npm install
# Never use this bypass in production.
# --------------------------------------------------------------------
