# Supabase (anon key is safe in the browser; never commit service_role secrets)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
#
# “Email rate limit exceeded”: Supabase’s built-in auth mail is heavily capped.
# Dashboard → Authentication → Emails → enable SMTP → use Resend:
#   Host smtp.resend.com | Port 587 | Username resend | Password = RESEND_API_KEY (same key as outbound mail).
#   “Sender email” must be allowed by Resend (verified domain; align with RESEND_FROM_EMAIL).

# Canonical URL for this deployment — emails & Supabase auth redirects (`redirectTo`, `emailRedirectTo`).
# In Supabase Dashboard → Authentication → URL Configuration: set Site URL to this origin and add these Redirect URLs:
#   {origin}/auth/callback
#   {origin}/reset-password
# Dev example: http://localhost:3000/auth/callback
NEXT_PUBLIC_SITE_URL=

# Transactional email branding (Resend / notify-email webhook)
EMAIL_BRAND_NAME=Zuno
# Absolute URL to logo image for HTML emails (PNG/SVG served over HTTPS)
EMAIL_LOGO_URL=
# Optional: override site origin for transactional emails only (defaults NEXT_PUBLIC_SITE_URL)
EMAIL_WEBSITE_URL=
EMAIL_SUPPORT_EMAIL=
EMAIL_SUPPORT_PHONE=
# Separate lines with | e.g. Zuno Capital | 123 Main St | City, ST
EMAIL_COMPANY_ADDRESS=
EMAIL_FOOTER_TAGLINE=

# Optional absolute URLs (defaults: site + /dashboard, /admin, /forgot-password)
EMAIL_DASHBOARD_URL=
EMAIL_ADMIN_URL=
EMAIL_PASSWORD_RESET_URL=

# Stay connected row: pairs Label|URL|Label|URL — X|https://x.com/zuno|Telegram|https://t.me/…
# Omitting EMAIL_SOCIAL_LINKS uses the same placeholder X/Telegram/LinkedIn row as dev email-preview.
EMAIL_SOCIAL_LINKS=

# Optional: CDN/base for social SVGs (no trailing slash). Default: {EMAIL_WEBSITE_URL}/email/social
EMAIL_SOCIAL_ICON_BASE_URL=

# Social row: `icons` (default) uses /email/social/*.svg; `text` = gold text links only (no icons).
# EMAIL_SOCIAL_LINK_STYLE=text

# Production-only: allow /email-preview?secret=THIS_VALUE (≥8 chars). Omit locally.
EMAIL_PREVIEW_SECRET=

# --------------------------------------------------------------------
# Local dev only — antivirus/VPN HTTPS inspection can break Node TLS
# (same error for npm and for /dashboard via the Next proxy):
# • Run app (no extra install): npm run dev:insecure-tls
# • Before npm install works, in PowerShell:
#   $env:NODE_TLS_REJECT_UNAUTHORIZED="0"; npm install
# Never use this bypass in production.
# --------------------------------------------------------------------
